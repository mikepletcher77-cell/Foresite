# Copy this file to ".env" and fill in real values before running.

# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=paste_a_long_random_string_here

# Get a free key at https://ridb.recreation.gov/  (top-right: "Get API Key")
RECREATION_GOV_API_KEY=paste_your_key_here

# Leave as-is for now (SQLite file, no separate database server needed)
DATABASE_URL=sqlite:///./foresite.db
